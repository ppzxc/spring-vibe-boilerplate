# =============================================================================
# Template API — Environment Variables
# =============================================================================
# docker-compose.yml의 env_file로 참조됨.
# 이 파일을 .env로 복사한 뒤 값을 수정하여 사용.
# .env 파일은 .gitignore에 의해 버전 관리에서 제외됨.
# =============================================================================

# --- Application ---
SPRING_PROFILES_ACTIVE=local
APP_NAME=template-api
SERVER_PORT=8080
SHUTDOWN_TIMEOUT=30s

# --- Logging ---
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO

# --- OpenTelemetry (optional) ---
# OTLP_ENDPOINT=http://localhost:4318/v1/traces

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=template
DB_USERNAME=template
DB_PASSWORD=changeme
# docker-compose로 app + postgres 함께 실행 시: postgres로 변경
DATASOURCE_URL=jdbc:postgresql://localhost:5432/template
DATASOURCE_USERNAME=template
DATASOURCE_PASSWORD=changeme
DATASOURCE_DRIVER=org.postgresql.Driver
JOOQ_DIALECT=POSTGRES

# --- Cache (adapter-output-cache 구성 후 활성화) ---
# CACHE_HOST=localhost
# CACHE_PORT=6379
# CACHE_PASSWORD=

# --- Message Queue (MQ adapter 추가 후 활성화) ---
# MQ_HOST=localhost
# MQ_PORT=5672
# MQ_USERNAME=
# MQ_PASSWORD=

# --- Security (인증 방식 선택 후 활성화) ---
# JWT_ISSUER_URI=http://localhost:9000
