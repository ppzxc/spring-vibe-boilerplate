# ============================================================
# Environment Variables for template-api
# Copy this file to .env and fill in the values.
# .env is git-ignored and should never be committed.
# ============================================================

# === App Runtime ===
SPRING_PROFILES_ACTIVE=local
APP_NAME=template-api
SERVER_PORT=8080
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
OTLP_ENDPOINT=

# === Database (uncomment when adapter-output-persist is configured) ===
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=template
# DB_USERNAME=
# DB_PASSWORD=

# === Cache (uncomment when adapter-output-cache is configured) ===
# CACHE_HOST=localhost
# CACHE_PORT=6379
# CACHE_PASSWORD=

# === Message Queue (uncomment when MQ adapter is added) ===
# MQ_HOST=localhost
# MQ_PORT=5672
# MQ_USERNAME=
# MQ_PASSWORD=
