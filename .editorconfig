root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.java]
max_line_length = 120

[*.{yaml,yml,json,toml,sql,kts,properties}]
indent_size = 2

[*.proto]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.bat]
end_of_line = crlf

[gradlew]
end_of_line = lf
